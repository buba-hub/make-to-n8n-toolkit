# ============================================
# Credentials — NE JAMAIS COMMITTER
# Copier ce fichier en `env.local` et remplir les valeurs
# ============================================

# --- n8n Instance ---
N8N_BASE_URL=https://your-n8n-instance.example.com
N8N_API_KEY=your_n8n_jwt_token

# --- Notion ---
NOTION_API_KEY=your_notion_api_key

# --- Freshdesk ---
FRESHDESK_API_KEY=your_freshdesk_api_key
FRESHDESK_DOMAIN=your-freshdesk-domain

# --- Google OAuth2 ---
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# --- Google Sheets ---
GOOGLE_SHEET_ID=your_google_sheet_id

# --- Airtable ---
AIRTABLE_BASE_ID=appXXXXXXXXXXXXX
AIRTABLE_TABLE_ID=tblXXXXXXXXXXXXX

# --- Google OAuth2 (compte secondaire, ex: calendrier) ---
# GOOGLE_SECONDARY_CLIENT_ID=
# GOOGLE_SECONDARY_CLIENT_SECRET=

# --- Pivot API (si applicable) ---
# PIVOT_CLIENT_ID=
# PIVOT_API_KEY=

# --- SFTP (si applicable) ---
# SFTP_HOST=
# SFTP_USER=
# SFTP_PASSWORD=
# SFTP_PATH=

# --- Autres (ajouter au besoin) ---
# SENDGRID_API_KEY=
# SLACK_WEBHOOK_URL=
